# Public Supabase key used only for non-email backend health probes.
SUPABASE_ANON_KEY=replace_with_anon_or_publishable_key

# Optional alert webhook for backend health check failures.
SYNTHETIC_ALERT_WEBHOOK_URL=replace_with_slack_or_other_webhook
SYNTHETIC_TIMEOUT_MS=20000

# Legacy magic-link monitor variables are intentionally omitted.
# Do not add SYNTHETIC_TEST_EMAIL or call /auth/v1/otp from this monitor.
